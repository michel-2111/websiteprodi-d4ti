generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  DOSEN
  GKM
}

enum Pangkat {
  PENATA_MUDA_IIIA
  PENATA_MUDA_TK_I_IIIB
  PENATA_IIIC
  PENATA_TK_I_IIID
  PEMBINA_IVA
  PEMBINA_TK_I_IVB
  PEMBINA_UTAMA_MUDA_IVC
  PEMBINA_UTAMA_MADYA_IVD
  PEMBINA_UTAMA_IVE
}

enum JabatanFungsional {
  TENAGA_PENGAJAR
  ASISTEN_AHLI
  LEKTOR
  LEKTOR_KEPALA
  GURU_BESAR
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String    
  role          Role      @default(ADMIN)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  dosenProfile  DosenProfile?
}

model DosenProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nidn              String?   @unique
  fotoUrl           String?
  kompetensi        String[]
  
  telepon           String?
  email             String?
  pangkat           Pangkat?
  jabatanFungsional JabatanFungsional?
  
  sertifikat        Sertifikat[]
  publikasi         Publikasi[]

  penelitianKetua   Penelitian[] @relation("PenelitianKetua")
  penelitianAnggota Penelitian[] @relation("PenelitianAnggota")

  pengabdianKetua   Pengabdian[] @relation("PengabdianKetua")
  pengabdianAnggota Pengabdian[] @relation("PengabdianAnggota")

  bukuAjarKetua     BukuAjar[]   @relation("BukuAjarKetua")
  bukuAjarAnggota   BukuAjar[]   @relation("BukuAjarAnggota")

  hkiKetua          Hki[]        @relation("HkiKetua")
  hkiAnggota        Hki[]        @relation("HkiAnggota")
}

model Sertifikat {
  id              String       @id @default(cuid())
  dosenProfileId  String
  dosenProfile    DosenProfile @relation(fields: [dosenProfileId], references: [id], onDelete: Cascade)
  namaPelatihan   String
  tahun           Int
  dokumenUrl      String?
}

model Publikasi {
  id              String       @id @default(cuid())
  dosenProfileId  String
  dosenProfile    DosenProfile @relation(fields: [dosenProfileId], references: [id], onDelete: Cascade)
  judul           String
  tahun           Int
  abstrak         String?      @db.Text
  lokasi          String?
  url             String?
}

model Penelitian {
  id              String         @id @default(cuid())
  judul           String
  tahun           Int
  gambarUrls      String[]
  deskripsi       String?        @db.Text
  
  ketuaId         String
  ketua           DosenProfile   @relation("PenelitianKetua", fields: [ketuaId], references: [id], onDelete: Cascade)
  anggota         DosenProfile[] @relation("PenelitianAnggota")
}

model Pengabdian {
  id              String         @id @default(cuid())
  judul           String
  tahun           Int
  gambarUrls      String[]
  deskripsi       String?        @db.Text
  
  ketuaId         String
  ketua           DosenProfile   @relation("PengabdianKetua", fields: [ketuaId], references: [id], onDelete: Cascade)
  anggota         DosenProfile[] @relation("PengabdianAnggota")
}

model BukuAjar {
  id              String         @id @default(cuid())
  judul           String
  tahun           Int
  deskripsi       String?        @db.Text
  link            String?

  ketuaId         String
  ketua           DosenProfile   @relation("BukuAjarKetua", fields: [ketuaId], references: [id], onDelete: Cascade)
  anggota         DosenProfile[] @relation("BukuAjarAnggota")
}

model Hki {
  id              String         @id @default(cuid())
  kategori        String         // Contoh: "Paten", "Hak Cipta", "Desain Industri"
  judul           String
  tahun           Int?
  link            String?

  ketuaId         String
  ketua           DosenProfile   @relation("HkiKetua", fields: [ketuaId], references: [id], onDelete: Cascade)
  anggota         DosenProfile[] @relation("HkiAnggota")
}

model LaporanGkm {
  id              String   @id @default(cuid())
  judul           String
  semester        String
  dokumenUrl      String
  dokumentasiUrls String[]
  createdAt       DateTime @default(now())
}

model Kurikulum {
  id          String       @id @default(cuid())
  nama        String
  tahunMulai  Int
  dokumenUrl  String?
  aktif       Boolean      @default(false)
  deskripsi   String?      @db.Text
  mataKuliah  MataKuliah[] 
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model MataKuliah {
  id          String     @id @default(cuid())
  kurikulumId String?
  kurikulum   Kurikulum? @relation(fields: [kurikulumId], references: [id])
  
  kodeMk      String
  nama        String
  sks         Int
  semester    Int
  jenis       String?
  deskripsi   String?    @db.Text
  
  @@unique([kurikulumId, kodeMk]) 
}

model Aktifitas {
  id          String    @id @default(cuid())
  nama        String
  deskripsi   String    @db.Text
  gambarUrls  String[]
  tanggal     DateTime?
}

model Fasilitas {
  id          String   @id @default(cuid())
  nama        String
  deskripsi   String   @db.Text
  gambarUrls  String[]
}

model StatistikMahasiswa {
  id        String   @id @default(cuid())
  tahun     Int      @unique
  pendaftar Int
  diterima  Int
  lulusan   Int
}

model Dokumen {
  id          String   @id @default(cuid())
  nama        String
  keterangan  String?  @db.Text
  fileUrl     String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum TipeVisiMisi {
  VISI_POLIMDO
  MISI_POLIMDO
  TUJUAN_POLIMDO
  VISI_PRODI
  MISI_PRODI
  TUJUAN_PRODI
  VISI_KEILMUAN
}

model VisiMisi {
  id        String       @id @default(cuid())
  tipe      TipeVisiMisi @unique
  konten    String       @db.Text
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Pengunjung {
  id        String   @id @default("global")
  total     Int      @default(0)
  updatedAt DateTime @updatedAt
}